# Local discovery / deploy helpers (not part of the app)
_discover.py
_deploy.py
_inspect_server.py
_setup_env_secrets.py
_i*.txt
_deploy_out.txt

# Playwright MCP captures (snapshots/screenshots)
.playwright-mcp/

# Bug/feature reports — personal notes, mirrored from /opt/dashboard/reports/
# on the server via _pull_reports.py. Don't push these to the public repo.
reports/

# Local planning / audit notes (not part of the app).
# Ignore contents by default, but track files that follow a clear
# convention so future sessions can find them:
#   - TEMPLATE.md   — plan structure
#   - *-design.md   — approved design specs (output of brainstorming)
#   - *-spec.md     — any other shareable spec
#   - *-plan.md     — approved implementation plans (output of writing-plans)
# Personal audit notes that don't match these patterns stay local.
plans_md/*
!plans_md/TEMPLATE.md
!plans_md/*-design.md
!plans_md/*-spec.md
!plans_md/*-plan.md

