@import 'tailwindcss';

/* ─────────────────────────────────────────────────────────────────────────────
 * Design tokens — ported VERBATIM from the legacy stylesheets so the React
 * rewrite is visually identical to the original. Don't introduce variations.
 *
 * Legacy variables: --bg, --surface, --surface2, --border, --text,
 * --text-muted, --text-dim, --radius, --radius-sm.
 * ──────────────────────────────────────────────────────────────────────────── */

@theme {
  --color-bg: #050505;
  --color-surface: #0e0e0e;
  --color-surface-2: #141414;
  --color-border: rgba(255, 255, 255, 0.07);

  --color-text: #e8e8e2;
  --color-text-muted: #505050;
  --color-text-dim: #888888;

  /* Per-page accent colors — used by .card / .ext-link via --card-color. */
  --color-page-plan:    #a78bfa;
  --color-page-todo:    #f472b6;
  --color-page-skole:   #f59e0b;
  --color-page-notes:   #34d399;  /* "notater" in legacy */
  --color-page-sport:   #22d3ee;
  --color-page-gaming:  #a3e635;
  --color-page-links:   #60a5fa;

  --color-success: #34d399;
  --color-warning: #f59e0b;
  --color-danger:  #f87171;
  --color-info:    #60a5fa;

  --radius:      12px;
  --radius-sm:   8px;

  --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  --font-mono: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;

  --sidebar-width: 220px;
  --page-max-width: 860px;
}

/* ─────────────────────────────────────────────────────────────────────────────
 * Base
 * ──────────────────────────────────────────────────────────────────────────── */

@layer base {
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    background: var(--color-bg);
    color-scheme: dark;
    scrollbar-gutter: stable;
    -webkit-text-size-adjust: 100%;
  }

  /* The signature dotted background — body-wide, faint. Without this the
   * whole site looks flat. Ported exactly from legacy. */
  body {
    font-family: var(--font-sans);
    background: var(--color-bg) !important;
    background-image: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.025) 1px,
      transparent 1px
    ) !important;
    background-size: 28px 28px !important;
    color: var(--color-text);
    min-height: 100vh;
    line-height: 1.5;
    scrollbar-gutter: stable;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    position: relative;
  }

  /* Diagonal sunbeam sweep — a SECOND copy of the dot pattern at higher
   * brightness, masked by a narrow diagonal stripe. The mask slides
   * across the viewport, fully exits past the corner, holds for ~2.6s,
   * then sweeps back the other way. Sits at z-index 0 so .app-shell
   * (z-index 1) is always above it. */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.06) 1px,
      transparent 1px
    );
    background-size: 28px 28px;
    /* Wide soft-edged stripe — peak fully opaque at 50%, with multi-stop
     * falloff so the brightness eases out gradually toward the edges
     * instead of cutting off sharply. */
    -webkit-mask-image: linear-gradient(
      135deg,
      transparent 30%,
      rgba(0, 0, 0, 0.10) 38%,
      rgba(0, 0, 0, 0.45) 45%,
      rgba(0, 0, 0, 1) 50%,
      rgba(0, 0, 0, 0.45) 55%,
      rgba(0, 0, 0, 0.10) 62%,
      transparent 70%
    );
    mask-image: linear-gradient(
      135deg,
      transparent 30%,
      rgba(0, 0, 0, 0.10) 38%,
      rgba(0, 0, 0, 0.45) 45%,
      rgba(0, 0, 0, 1) 50%,
      rgba(0, 0, 0, 0.45) 55%,
      rgba(0, 0, 0, 0.10) 62%,
      transparent 70%
    );
    /* Mask is 2.5× the element so the stripe has room to slide fully
     * past either corner. */
    -webkit-mask-size: 250% 250%;
    mask-size: 250% 250%;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    animation: dot-sunbeam 34s ease-in-out infinite;
    will-change: mask-position;
  }
  /* Animation timing (34s total):
   *   0%–8%    (2.7s)  hold past bottom-right corner
   *   8%–50%   (14.3s) slow sweep across viewport
   *   50%–58%  (2.7s)  hold past top-left corner
   *   58%–100% (14.3s) slow sweep back */
  @keyframes dot-sunbeam {
    0%, 8%    { -webkit-mask-position: -20% -20%; mask-position: -20% -20%; }
    50%, 58%  { -webkit-mask-position: 120% 120%; mask-position: 120% 120%; }
    100%      { -webkit-mask-position: -20% -20%; mask-position: -20% -20%; }
  }
  @media (prefers-reduced-motion: reduce) {
    body::after { animation: none; }
  }

  /* Pages that opt out of the dotted background + sweep — Notes uses a
   * solid surface instead, matching legacy notes.html. AppShell adds
   * `.route-no-grid` to the body when the active route should be plain. */
  body.route-no-grid { background-image: none !important; }
  body.route-no-grid::after { display: none; }

  ::-webkit-scrollbar { width: 10px; height: 10px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.06);
    border-radius: 10px;
    border: 2px solid transparent;
    background-clip: padding-box;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.12);
    background-clip: padding-box;
    border: 2px solid transparent;
  }
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { scrollbar-width: none; }

  button { font-family: inherit; cursor: pointer; }
  input, select, textarea { font-family: inherit; color: inherit; }
  a { color: inherit; text-decoration: none; }
}

/* ─────────────────────────────────────────────────────────────────────────────
 * App shell — sidebar + main + page wrapper. Ported verbatim.
 * ──────────────────────────────────────────────────────────────────────────── */

@layer components {
  .app-shell {
    display: flex;
    min-height: 100vh;
    position: relative;
    z-index: 1;
  }

  /* ── Sidebar ─────────────────────────────────────────────────────────── */
  .sidebar {
    width: var(--sidebar-width);
    flex-shrink: 0;
    background: rgba(10, 10, 10, 0.85);
    border-right: 1px solid rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    padding: 24px 0;
    z-index: 90;
  }
  .sidebar-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 18px 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    margin-bottom: 16px;
    text-decoration: none;
    color: var(--color-text);
  }
  .sidebar-logo-mark {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.7);
  }
  .sidebar-logo-text {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.10em;
    text-transform: uppercase;
  }
  .sidebar-section-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 0 18px;
    margin: 8px 0 4px;
  }
  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 20px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-dim);
    text-decoration: none;
    box-shadow: inset 3px 0 0 transparent;
    transition: background 0.15s, color 0.15s, box-shadow 0.15s;
    white-space: nowrap;
  }
  .sidebar-link:hover {
    color: var(--color-text);
    background: rgba(0, 0, 0, 0.22);
  }
  .sidebar-link.active {
    color: var(--color-text);
    box-shadow: inset 3px 0 0 rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.05);
  }
  .sidebar-link svg { opacity: 0.6; flex-shrink: 0; }
  .sidebar-link.active svg { opacity: 1; }

  /* ── Main content + page wrapper ─────────────────────────────────────── */
  .main-content { flex: 1; min-width: 0; }
  .page {
    max-width: var(--page-max-width);
    margin: 0 auto;
    padding: 36px 32px 72px;
  }
  @media (max-width: 768px) {
    .page { padding: 24px 16px 56px; }
  }

  /* ── Mobile header (hamburger) ───────────────────────────────────────── */
  .mobile-header {
    background: rgba(8, 8, 8, 0.92);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  .header-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--color-text);
  }
  .header-logo-mark {
    width: 30px;
    height: 30px;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.7);
  }
  .header-title-main {
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--color-text);
  }
  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    background: rgba(255, 255, 255, 0.6);
    border-radius: 2px;
  }

  /* ── Page header (eyebrow + title + subtitle) ────────────────────────── */
  .page-header { margin-bottom: 36px; }
  .page-header-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 8px;
  }
  .page-header-title {
    font-size: 1.9rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1.1;
  }
  .page-header-sub {
    font-size: 0.88rem;
    color: var(--color-text-dim);
    margin-top: 6px;
  }
  @media (max-width: 768px) {
    .page-header-title { font-size: 1.5rem; }
  }

  /* ── Category cards (.card with .plan / .skole / etc. variants) ──────── */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
  }
  .card {
    display: flex;
    align-items: center;
    gap: 16px;
    text-decoration: none;
    background: rgba(0, 0, 0, 0.22);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: var(--radius);
    padding: 20px 20px;
    backdrop-filter: blur(6px) saturate(130%);
    -webkit-backdrop-filter: blur(6px) saturate(130%);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    transition: border-color 0.15s, transform 0.12s, box-shadow 0.15s;
    position: relative;
    overflow: hidden;
  }
  .card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px;
    border-radius: 2px 0 0 2px;
    background: var(--card-color, rgba(255, 255, 255, 0.2));
    opacity: 0.5;
  }
  .card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; bottom: 0;
    width: 60%;
    background: radial-gradient(
      ellipse at -10% 50%,
      color-mix(in srgb, var(--card-color, #fff) 6%, transparent),
      transparent 70%
    );
    pointer-events: none;
  }
  .card:hover {
    border-color: rgba(255, 255, 255, 0.13);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .card-icon {
    width: 38px;
    height: 38px;
    flex-shrink: 0;
    background: color-mix(in srgb, var(--card-color, #fff) 7%, rgba(0, 0, 0, 0.4));
    border: 1px solid color-mix(in srgb, var(--card-color, #fff) 12%, transparent);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--card-color, rgba(255, 255, 255, 0.5));
    position: relative;
    z-index: 1;
  }
  .card-body { min-width: 0; position: relative; z-index: 1; }
  .card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .card-desc {
    font-size: 0.78rem;
    margin-top: 2px;
    color: color-mix(in srgb, var(--card-color, #888) 25%, #606060);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .card-arrow {
    position: absolute;
    top: 50%;
    right: 16px;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    opacity: 0;
    z-index: 1;
    transition: opacity 0.15s, transform 0.15s;
  }
  .card:hover .card-arrow {
    opacity: 1;
    transform: translateY(-50%) translateX(2px);
  }

  /* Card colour variants */
  .card.plan    { --card-color: var(--color-page-plan); }
  .card.todo    { --card-color: var(--color-page-todo); }
  .card.skole   { --card-color: var(--color-page-skole); }
  .card.notater { --card-color: var(--color-page-notes); }
  .card.sport   { --card-color: var(--color-page-sport); }
  .card.gaming  { --card-color: var(--color-page-gaming); }

  /* ── Section header (used by every section on home + other pages) ────── */
  .section-header {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .section-header-link {
    display: flex;
    align-items: center;
    gap: 4px;
    color: var(--color-text-muted);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    transition: color 0.15s;
  }
  .section-header-link:hover { color: rgba(255, 255, 255, 0.6); }

  /* ── External link cards (.ext-link, used in carousels and Lenker page) */
  .ext-grid-wrap {
    overflow: hidden;
    position: relative;
  }
  .ext-grid-wrap::before,
  .ext-grid-wrap::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    pointer-events: none;
    z-index: 2;
  }
  .ext-grid-wrap::before {
    left: 0;
    background: linear-gradient(to right, var(--color-bg) 0%, transparent 100%);
  }
  .ext-grid-wrap::after {
    right: 0;
    background: linear-gradient(to left, var(--color-bg) 0%, transparent 100%);
  }
  .ext-grid {
    display: flex;
    flex-direction: row;
    gap: 10px;
    overflow-x: scroll;
    overflow-y: visible;
    -webkit-overflow-scrolling: touch;
    cursor: grab;
    user-select: none;
    scrollbar-width: none;
    padding-bottom: 20px;
    margin-bottom: -20px;
  }
  .ext-grid:active { cursor: grabbing; }
  .ext-grid::-webkit-scrollbar { display: none; }
  .ext-grid .ext-link { flex: 0 0 148px; min-height: 100px; }
  .ext-link {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 15px 15px 13px;
    background: rgba(0, 0, 0, 0.22);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: var(--radius);
    text-decoration: none;
    backdrop-filter: blur(6px) saturate(130%);
    -webkit-backdrop-filter: blur(6px) saturate(130%);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    transition: border-color 0.15s, transform 0.12s, box-shadow 0.15s;
    position: relative;
    overflow: hidden;
    min-height: 100px;
  }
  .ext-link::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 55%;
    background: radial-gradient(
      ellipse at 50% 110%,
      color-mix(in srgb, var(--ext-color, #fff) 7%, transparent),
      transparent 70%
    );
    pointer-events: none;
  }
  .ext-link::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--ext-color, rgba(255, 255, 255, 0.2));
    opacity: 0.35;
  }
  .ext-link:hover {
    border-color: rgba(255, 255, 255, 0.14);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .ext-link-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 14px;
  }
  .ext-link-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .ext-link-icon-wrap img,
  .ext-link-icon-wrap svg {
    width: 26px;
    height: 26px;
    border-radius: 4px;
    display: block;
  }
  .ext-link-arrow {
    color: rgba(255, 255, 255, 0.18);
    transition: color 0.15s, transform 0.15s;
    margin-top: 1px;
    flex-shrink: 0;
  }
  .ext-link:hover .ext-link-arrow {
    color: rgba(255, 255, 255, 0.55);
    transform: translate(1px, -1px);
  }
  .ext-link-name {
    font-size: 0.84rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.75);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .ext-link-sub {
    font-size: 0.69rem;
    font-weight: 500;
    color: color-mix(in srgb, var(--ext-color, #888) 25%, #606060);
    margin-top: 3px;
    letter-spacing: 0.01em;
  }
  .ext-link:hover .ext-link-name { color: #fff; }

  /* ── Dagens plan / today list ────────────────────────────────────────── */
  .today-list { display: flex; flex-direction: column; gap: 6px; }
  .today-item {
    background: rgba(0, 0, 0, 0.22);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-sm);
    padding: 10px 14px;
    transition: background 0.12s, border-color 0.12s;
  }
  .today-item:hover {
    background: rgba(0, 0, 0, 0.22);
    border-color: rgba(255, 255, 255, 0.10);
  }
  .today-item.past {
    opacity: 0.28;
    filter: grayscale(1);
    pointer-events: none;
  }
  .today-item-inner {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: inherit;
  }
  .today-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .today-time {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-dim);
    min-width: 88px;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }
  .today-title {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-text);
    flex: 1;
    min-width: 0;
  }
  .today-loc {
    font-size: 0.74rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 160px;
  }
  .today-now-badge {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 20px;
    background: rgba(167, 139, 250, 0.15);
    color: #a78bfa;
    border: 1px solid rgba(167, 139, 250, 0.3);
    flex-shrink: 0;
  }
  .today-empty {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    padding: 18px 0;
  }
  .today-pdfs {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 6px;
    padding-left: 32px;
  }
  .today-pdf-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.72rem;
    font-weight: 600;
    background: rgba(0, 0, 0, 0.22);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 6px;
    padding: 4px 10px;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.7);
    transition: background 0.12s, border-color 0.12s, color 0.12s;
  }
  .today-pdf-link:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.28);
    color: rgba(255, 255, 255, 0.95);
  }

  /* ── News cards (160×240, image-fill, gradient overlay) ──────────────── */
  .news-wrap {
    overflow: hidden;
    position: relative;
    -webkit-mask-image: linear-gradient(
      to right,
      rgba(0, 0, 0, 1) 0%,
      rgba(0, 0, 0, 1) 92%,
      rgba(0, 0, 0, 0) 100%
    );
    mask-image: linear-gradient(
      to right,
      rgba(0, 0, 0, 1) 0%,
      rgba(0, 0, 0, 1) 92%,
      rgba(0, 0, 0, 0) 100%
    );
  }
  .news-list {
    display: flex;
    flex-direction: row;
    gap: 10px;
    overflow-x: scroll;
    scrollbar-width: none;
    cursor: grab;
    user-select: none;
    padding-bottom: 20px;
    margin-bottom: -20px;
  }
  .news-list::-webkit-scrollbar { display: none; }
  .news-list:active { cursor: grabbing; }
  .news-item {
    flex: 0 0 160px;
    height: 240px;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
    position: relative;
  }
  .news-item:hover {
    border-color: rgba(255, 255, 255, 0.12);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
  }
  .news-img { position: absolute; inset: 0; }
  .news-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .news-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.88) 0%,
      rgba(0, 0, 0, 0.2) 55%,
      transparent 100%
    );
  }
  .news-title {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 12px 11px;
    font-size: 0.78rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.35;
  }
  .news-loading {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    padding: 8px 0;
  }
  /* Source dropdown for the news section header */
  .news-source-select {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.10);
    color: var(--color-text-dim);
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    font-family: inherit;
    cursor: pointer;
    outline: none;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  .news-source-select:hover {
    border-color: rgba(255, 255, 255, 0.22);
    color: var(--color-text);
  }
  .news-source-select option {
    background: #0e0e0e;
    color: var(--color-text);
  }

  /* ── Section spacing ─────────────────────────────────────────────────── */
  .sections-container { display: flex; flex-direction: column; }
  .sections-container > * + * { margin-top: 36px; }

  /* ── Tools page list ─────────────────────────────────────────────────── */
  .tools-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .tool-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    background: rgba(0, 0, 0, 0.22);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s, transform 0.12s, background 0.15s, box-shadow 0.15s;
    backdrop-filter: blur(6px) saturate(130%);
    -webkit-backdrop-filter: blur(6px) saturate(130%);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }
  .tool-row:hover {
    border-color: rgba(255, 255, 255, 0.13);
    transform: translateX(2px);
    background: rgba(0, 0, 0, 0.32);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .tool-row-icon {
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.75);
    flex-shrink: 0;
  }
  .tool-row-body {
    flex: 1;
    min-width: 0;
  }
  .tool-row-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .tool-row-desc {
    font-size: 0.76rem;
    color: var(--color-text-muted);
    margin-top: 2px;
  }
  .tool-row-arrow {
    color: var(--color-text-muted);
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity 0.15s, transform 0.15s;
  }
  .tool-row:hover .tool-row-arrow {
    opacity: 1;
    transform: translateX(2px);
  }

  .tools-back-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 6px 10px;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .tools-back-link:hover {
    color: var(--color-text);
    border-color: rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.04);
  }

  /* ── Calculator tool ─────────────────────────────────────────────────── */
  .calc-input-box {
    background: rgba(0, 0, 0, 0.32);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: var(--radius-sm);
    padding: 14px 18px;
    display: flex;
    align-items: center;
  }
  .calc-output-box {
    margin-top: 6px;
    background: rgba(167, 139, 250, 0.04);
    border: 1px solid rgba(167, 139, 250, 0.14);
    border-radius: var(--radius-sm);
    padding: 14px 18px;
    display: flex;
    align-items: baseline;
    gap: 12px;
    min-height: 62px;
  }
  .calc-output-label {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: rgba(167, 139, 250, 0.55);
    font-weight: 700;
    flex-shrink: 0;
  }
  .calc-input {
    background: none;
    border: none;
    outline: none;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 1.2rem;
    width: 100%;
    padding: 0;
    line-height: 1.4;
    caret-color: #a78bfa;
  }
  .calc-input::placeholder { color: var(--color-text-muted); }
  .calc-result {
    font-family: var(--font-mono);
    font-size: 1.55rem;
    font-weight: 700;
    color: #a78bfa;
    line-height: 1.2;
    letter-spacing: -0.01em;
    word-break: break-all;
    flex: 1;
    min-width: 0;
  }
  .calc-result.error { color: #f87171; font-size: 0.85rem; font-weight: 600; }
  .calc-result.placeholder { color: var(--color-text-muted); font-size: 0.85rem; font-weight: 500; font-style: italic; }

  .calc-keys {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 4px;
    margin-top: 12px;
  }
  .calc-key {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--color-text-dim);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 8px 0;
    cursor: pointer;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
  }
  .calc-key:hover {
    background: rgba(255, 255, 255, 0.09);
    color: var(--color-text);
    border-color: rgba(255, 255, 255, 0.16);
  }
  .calc-key.accent {
    color: #a78bfa;
    border-color: rgba(167, 139, 250, 0.20);
  }
  .calc-key.accent:hover {
    background: rgba(167, 139, 250, 0.10);
    border-color: rgba(167, 139, 250, 0.40);
  }

  .calc-history {
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-height: 180px;
    overflow-y: auto;
  }
  .calc-history-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    padding: 6px 10px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    cursor: pointer;
    transition: background 0.12s;
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .calc-history-row:hover { background: rgba(255, 255, 255, 0.06); }
  .calc-history-expr { color: var(--color-text-dim); flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .calc-history-result { color: var(--color-text); font-weight: 700; flex-shrink: 0; }
  .calc-history-empty {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    text-align: center;
    padding: 12px 0;
  }

  /* ── Weather widget on the home page ─────────────────────────────────── */
  .weather-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 16px;
    align-items: stretch;
    background: rgba(0, 0, 0, 0.22);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: var(--radius);
    padding: 16px 18px;
    backdrop-filter: blur(6px) saturate(130%);
    -webkit-backdrop-filter: blur(6px) saturate(130%);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }
  .weather-current {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .weather-location {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .weather-location button {
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.25);
    padding: 2px 4px;
    border-radius: 4px;
    line-height: 0;
    transition: color 0.15s;
  }
  .weather-location button:hover { color: rgba(255, 255, 255, 0.7); }
  .weather-temp {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }
  .weather-temp-main {
    font-size: 2.4rem;
    font-weight: 800;
    line-height: 1;
    color: var(--color-text);
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
  }
  .weather-icon-big { font-size: 2rem; line-height: 1; }
  .weather-desc {
    font-size: 0.82rem;
    color: var(--color-text-dim);
  }
  .weather-daily {
    display: flex;
    gap: 6px;
    align-items: stretch;
  }
  .weather-day {
    flex: 0 0 auto;
    width: 52px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 6px 4px;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-sm);
    gap: 4px;
  }
  .weather-day-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .weather-day-icon { font-size: 1.1rem; line-height: 1; }
  .weather-day-temps {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-dim);
    text-align: center;
    line-height: 1.2;
    font-variant-numeric: tabular-nums;
  }
  .weather-day-temps strong {
    color: var(--color-text);
    font-weight: 700;
  }
  /* Mobile: stack daily list under current */
  @media (max-width: 640px) {
    .weather-card { grid-template-columns: 1fr; }
    .weather-daily { overflow-x: auto; }
  }

  /* Drag-reorder handle for the home page sections — 6-dot grip icon
   * inside each section header. Visible at low opacity, brighter on hover,
   * grab/grabbing cursor depending on state. */
  .db-grip-handle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: grab;
    opacity: 0.18;
    margin-right: 8px;
    flex-shrink: 0;
    transition: opacity 0.15s;
    line-height: 0;
    /* Nudge the SVG so it sits in the optical center of the row label. */
    vertical-align: middle;
  }
  .db-grip-handle:hover { opacity: 0.55; }
  .db-grip-handle:active { cursor: grabbing; }
  /* While the section is being dragged the original placeholder fades out. */
  .db-section-dragging { opacity: 0.25; }

  /* ──────────────────────────────────────────────────────────────────────
   * Plan page — full-height week calendar
   *
   * The calendar needs a fixed-viewport shell so it can scroll
   * independently from the body. AppShell adds `.app-shell-full` and
   * `.main-content-full` when the route is /plan.
   * ──────────────────────────────────────────────────────────────────── */
  .app-shell-full {
    height: 100vh;
    overflow: hidden;
  }
  .main-content-full {
    display: flex;
    flex-direction: column;
    height: 100vh;
    overflow: hidden;
  }

  .week-toolbar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    background: rgba(10, 10, 10, 0.8);
    flex-shrink: 0;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .week-title {
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    min-width: 180px;
  }
  .week-nav-btn {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.10);
    color: var(--color-text);
    border-radius: 7px;
    padding: 6px 10px;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 600;
    transition: background 0.15s, border-color 0.15s;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .week-nav-btn:hover {
    background: rgba(255, 255, 255, 0.10);
    border-color: rgba(255, 255, 255, 0.18);
  }
  .week-today-btn {
    background: rgba(96, 165, 250, 0.12);
    border: 1px solid rgba(96, 165, 250, 0.25);
    color: #93c5fd;
  }
  .week-today-btn:hover {
    background: rgba(96, 165, 250, 0.20);
  }
  .week-add-btn {
    margin-left: auto;
    background: rgba(96, 165, 250, 0.15);
    border: 1px solid rgba(96, 165, 250, 0.30);
    color: #93c5fd;
    border-radius: 7px;
    padding: 6px 14px;
    cursor: pointer;
    font-size: 0.82rem;
    font-weight: 600;
    transition: background 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
  .week-add-btn:hover {
    background: rgba(96, 165, 250, 0.25);
  }

  .cal-scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: auto;
  }
  .cal-wrap { min-width: 700px; }

  .cal-header {
    display: grid;
    grid-template-columns: 52px repeat(7, 1fr);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    background: rgba(10, 10, 10, 0.9);
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .cal-header-spacer {
    border-right: 1px solid rgba(255, 255, 255, 0.07);
  }
  .cal-day-header {
    padding: 10px 8px 8px;
    text-align: center;
    border-right: 1px solid rgba(255, 255, 255, 0.05);
    font-size: 0.75rem;
    font-weight: 600;
  }
  .cal-day-header .day-name {
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.65rem;
  }
  .cal-day-header .day-num {
    font-size: 1.15rem;
    font-weight: 700;
    margin-top: 2px;
    color: var(--color-text);
    line-height: 1;
  }
  .cal-day-header.today .day-num {
    background: #60a5fa;
    color: #000;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin: 2px auto 0;
  }
  .cal-day-header.today .day-name { color: #60a5fa; }
  /* Holiday styling — red day-name + small label under the date number */
  .cal-day-header.holiday .day-name { color: #f87171; }
  .cal-day-header .day-holiday-label {
    display: block;
    margin-top: 3px;
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #f87171;
    line-height: 1.1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    padding: 0 4px;
  }
  /* Tint today's column when it's also a holiday */
  .cal-day-col.holiday-col { background: rgba(248, 113, 113, 0.025); }

  .cal-body {
    display: grid;
    grid-template-columns: 52px repeat(7, 1fr);
  }

  .cal-time-col {
    border-right: 1px solid rgba(255, 255, 255, 0.07);
  }
  .cal-time-slot {
    height: 80px; /* 1 hour = 80px */
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    padding: 4px 8px 0 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    position: relative;
  }
  .cal-time-slot::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    top: 50%;
    border-top: 1px dashed rgba(255, 255, 255, 0.04);
  }
  .cal-time-label {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    line-height: 1;
    margin-top: -6px;
    white-space: nowrap;
  }

  .cal-day-col {
    border-right: 1px solid rgba(255, 255, 255, 0.05);
    position: relative;
    cursor: default;
  }
  .cal-day-col.today-col {
    background: rgba(96, 165, 250, 0.02);
  }
  .cal-hour-row {
    height: 80px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .cal-now-line {
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: #f87171;
    z-index: 5;
    pointer-events: none;
  }
  .cal-now-line::before {
    content: '';
    position: absolute;
    left: -4px;
    top: -4px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #f87171;
  }

  .cal-event {
    position: absolute;
    border-radius: 6px;
    padding: 4px 7px;
    font-size: 0.7rem;
    line-height: 1.3;
    overflow: hidden;
    cursor: pointer;
    z-index: 3;
    transition: filter 0.12s, transform 0.12s;
    border-left: 3px solid transparent;
    user-select: none;
  }
  .cal-event:hover {
    filter: brightness(1.15);
    transform: translateY(-1px);
    z-index: 4;
  }
  .cal-event .ev-title {
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cal-event .ev-sub {
    font-size: 0.62rem;
    opacity: 0.75;
    margin-top: 1px;
  }
  .cal-event .ev-loc {
    font-size: 0.6rem;
    opacity: 0.6;
    margin-top: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cal-event .ev-pdfs {
    margin-top: 5px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .cal-event .ev-pdf-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.62rem;
    font-weight: 700;
    background: rgba(0, 0, 0, 0.45);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 5px;
    padding: 3px 7px;
    opacity: 0.9;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.88);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
    transition: background 0.12s, border-color 0.12s, opacity 0.12s;
  }
  .cal-event .ev-pdf-link:hover {
    opacity: 1;
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.35);
  }

  /* Plan modal — uses native form controls + day buttons + circle swatches */
  .plan-day-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .plan-day-btn {
    padding: 5px 10px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 700;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.10);
    color: var(--color-text-dim);
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
    letter-spacing: 0.04em;
  }
  .plan-day-btn.selected {
    background: rgba(96, 165, 250, 0.18);
    border-color: rgba(96, 165, 250, 0.35);
    color: #93c5fd;
  }
  .plan-color-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .plan-color-swatch {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.12s, transform 0.12s;
    flex-shrink: 0;
  }
  .plan-color-swatch.selected {
    border-color: #fff;
    transform: scale(1.2);
  }

  /* ──────────────────────────────────────────────────────────────────────
   * Legacy modal — used by Modal.tsx via Radix Dialog. Ported verbatim
   * from the dialog styles spread across the legacy pages so every modal
   * in the app shares one look.
   * ──────────────────────────────────────────────────────────────────── */
  .lm-overlay {
    position: fixed;
    inset: 0;
    z-index: 300;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .lm-content {
    position: fixed;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 14px;
    padding: 24px;
    max-width: 95vw;
    max-height: 90vh;
    overflow-y: auto;
    z-index: 301;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.7);
  }
  .lm-title {
    font-size: 1rem;
    font-weight: 800;
    margin-bottom: 4px;
    letter-spacing: 0.02em;
    color: var(--color-text);
  }
  .lm-description {
    font-size: 0.78rem;
    color: var(--color-text-dim);
    margin-bottom: 16px;
  }
  .lm-title:last-child,
  .lm-title + .lm-body { margin-top: 16px; }

  /* Form rows inside the modal — uppercase tracked label above each field. */
  .modal-row {
    margin-bottom: 14px;
  }
  .modal-row > label,
  .modal-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-text-dim);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 5px;
  }
  .modal-label-hint {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: var(--color-text-muted);
    margin-left: 4px;
  }
  .modal-input,
  .modal-row input:not([type='checkbox']):not([type='radio']):not([type='color']),
  .modal-row select,
  .modal-row textarea {
    width: 100%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.10);
    color: var(--color-text);
    border-radius: 8px;
    padding: 9px 12px;
    font-size: 0.88rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s;
  }
  .modal-input:focus,
  .modal-row input:focus,
  .modal-row select:focus,
  .modal-row textarea:focus {
    border-color: rgba(96, 165, 250, 0.5);
  }
  .modal-row-2col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 14px;
  }

  /* Split hour : minute time selectors */
  .time-sel-wrap {
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .time-sel-wrap select {
    flex: 1;
  }
  .time-colon {
    color: var(--color-text);
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }

  /* Recurring checkbox row */
  .modal-recurring-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .modal-recurring-row label {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-text-dim);
    cursor: pointer;
  }
  .modal-recurring-row input[type='checkbox'] {
    width: 16px;
    height: 16px;
    cursor: pointer;
    accent-color: #60a5fa;
  }

  /* Color picker row */
  .modal-color-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .modal-color-swatch {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.12s, transform 0.12s;
    flex-shrink: 0;
    padding: 0;
  }
  .modal-color-swatch.selected {
    border-color: #fff;
    transform: scale(1.2);
  }
  .modal-color-custom {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
  }
  .modal-color-custom label {
    font-size: 0.7rem;
    color: var(--color-text-dim);
  }
  .modal-color-custom input[type='color'] {
    width: 32px;
    height: 28px;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: none;
    cursor: pointer;
    padding: 2px;
  }

  /* Day-of-week selector buttons (used by Plan modal) */
  .modal-day-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .modal-day-btn {
    padding: 5px 10px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 700;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.10);
    color: var(--color-text-dim);
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
    letter-spacing: 0.04em;
  }
  .modal-day-btn.selected {
    background: rgba(96, 165, 250, 0.18);
    border-color: rgba(96, 165, 250, 0.35);
    color: #93c5fd;
  }

  /* Action buttons row */
  .modal-actions {
    display: flex;
    gap: 10px;
    margin-top: 20px;
  }
  .modal-btn-primary {
    flex: 1;
    padding: 10px;
    border-radius: 8px;
    border: none;
    background: rgba(96, 165, 250, 0.18);
    color: #93c5fd;
    font-size: 0.88rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s;
  }
  .modal-btn-primary:hover {
    background: rgba(96, 165, 250, 0.30);
  }
  .modal-btn-cancel {
    padding: 10px 18px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.10);
    color: var(--color-text-dim);
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .modal-btn-cancel:hover {
    background: rgba(255, 255, 255, 0.09);
  }
  .modal-btn-delete {
    padding: 10px 14px;
    border-radius: 8px;
    border: none;
    background: rgba(248, 113, 113, 0.12);
    color: #fca5a5;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .modal-btn-delete:hover {
    background: rgba(248, 113, 113, 0.24);
  }

  /* ──────────────────────────────────────────────────────────────────────
   * Modal variants — `compact` (Plan-style, default) and `standard`
   * (Links-style with header X close + right-aligned footer).
   * ──────────────────────────────────────────────────────────────────── */
  .lm-compact { padding: 24px; }
  .lm-standard { padding: 0; }
  .lm-header {
    padding: 20px 22px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }
  .lm-title-standard {
    font-size: 0.95rem;
    font-weight: 800;
    color: var(--color-text);
  }
  .lm-close {
    width: 28px;
    height: 28px;
    border-radius: 7px;
    border: none;
    background: rgba(255, 255, 255, 0.07);
    color: var(--color-text-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
    padding: 0;
  }
  .lm-close:hover {
    background: rgba(255, 255, 255, 0.13);
    color: var(--color-text);
  }
  .lm-body {
    padding: 18px 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex: 1;
  }
  .lm-footer {
    padding: 0 22px 20px;
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    flex-shrink: 0;
  }

  /* Standard modal buttons (used by Links and other "standard" modals) */
  .btn-cancel-std {
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.10);
    background: none;
    color: var(--color-text-dim);
    font-family: inherit;
    font-size: 0.84rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
  }
  .btn-cancel-std:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-text);
  }
  .btn-save-std {
    padding: 8px 18px;
    border-radius: 8px;
    background: rgba(167, 139, 250, 0.15);
    border: 1px solid rgba(167, 139, 250, 0.30);
    color: #a78bfa;
    font-family: inherit;
    font-size: 0.84rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .btn-save-std:hover {
    background: rgba(167, 139, 250, 0.28);
    border-color: rgba(167, 139, 250, 0.50);
  }
  .btn-delete-std {
    padding: 8px 14px;
    border-radius: 8px;
    border: 1px solid rgba(248, 113, 113, 0.25);
    background: rgba(248, 113, 113, 0.10);
    color: #fca5a5;
    font-family: inherit;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    margin-right: auto;
  }
  .btn-delete-std:hover {
    background: rgba(248, 113, 113, 0.20);
  }

  /* ──────────────────────────────────────────────────────────────────────
   * Lenker page — small two-line header + grid of link cards
   * ──────────────────────────────────────────────────────────────────── */
  .page-inner {
    padding: 28px 32px;
  }
  @media (max-width: 768px) {
    .page-inner { padding: 20px 16px; }
  }
  .lenker-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
  }
  .lenker-title-wrap {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .lenker-title {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }
  .lenker-sub {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
  .btn-new-link {
    display: flex;
    align-items: center;
    gap: 7px;
    background: rgba(167, 139, 250, 0.12);
    border: 1px solid rgba(167, 139, 250, 0.28);
    border-radius: 8px;
    color: #a78bfa;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 8px 14px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    font-family: inherit;
  }
  .btn-new-link:hover {
    background: rgba(167, 139, 250, 0.22);
    border-color: rgba(167, 139, 250, 0.45);
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(148px, 1fr));
    gap: 10px;
  }
  .links-empty {
    grid-column: 1 / -1;
    padding: 60px 20px;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    line-height: 1.8;
  }

  /* Card actions (edit + delete) — top-right, hover-only */
  .card-actions {
    position: absolute;
    top: 8px;
    right: 8px;
    display: flex;
    gap: 4px;
    opacity: 0;
    transition: opacity 0.15s;
    z-index: 2;
  }
  .ext-link:hover .card-actions {
    opacity: 1;
  }
  .card-btn {
    width: 22px;
    height: 22px;
    border-radius: 5px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.45);
    transition: background 0.12s, color 0.12s;
    padding: 0;
  }
  .card-btn:hover {
    background: rgba(255, 255, 255, 0.10);
    color: #fff;
  }
  .card-btn.del:hover {
    background: rgba(239, 68, 68, 0.20);
    color: #ef4444;
    border-color: rgba(239, 68, 68, 0.30);
  }

  /* Favorite star button in card-bottom */
  .fav-btn {
    background: none;
    border: none;
    padding: 1px 0 0;
    cursor: pointer;
    line-height: 1;
    font-size: 13px;
    flex-shrink: 0;
    z-index: 2;
    position: relative;
    color: rgba(255, 255, 255, 0.18);
    transition: color 0.15s, transform 0.10s;
  }
  .fav-btn:hover {
    transform: scale(1.25);
    color: rgba(255, 255, 255, 0.55);
  }
  .fav-btn.favorited {
    color: #f5c518;
  }
  .card-bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 6px;
  }
  .card-bottom-text { min-width: 0; }

  /* ──────────────────────────────────────────────────────────────────────
   * Icon picker (used inside the Links modal)
   * ──────────────────────────────────────────────────────────────────── */
  .icon-picker-tabs {
    display: flex;
    gap: 2px;
    margin-bottom: 10px;
  }
  .icon-tab {
    flex: 1;
    padding: 7px 8px;
    font-size: 0.75rem;
    font-weight: 600;
    font-family: inherit;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    background: none;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
  }
  .icon-tab[data-state='active'],
  .icon-tab.active {
    background: rgba(167, 139, 250, 0.12);
    color: #a78bfa;
    border-color: rgba(167, 139, 250, 0.30);
  }

  .favicon-preview {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 8px;
  }
  .favicon-preview img {
    width: 28px;
    height: 28px;
    border-radius: 5px;
  }
  .favicon-preview-text {
    font-size: 0.8rem;
    color: var(--color-text-dim);
  }

  .emoji-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    max-height: 190px;
    overflow-y: auto;
  }
  .emoji-cell {
    width: 34px;
    height: 34px;
    border-radius: 7px;
    border: 1px solid transparent;
    background: rgba(255, 255, 255, 0.04);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 18px;
    transition: background 0.12s, border-color 0.12s;
    padding: 0;
  }
  .emoji-cell:hover {
    background: rgba(255, 255, 255, 0.09);
  }
  .emoji-cell.selected {
    background: rgba(167, 139, 250, 0.15);
    border-color: rgba(167, 139, 250, 0.40);
  }

  .img-blend-row {
    display: flex;
    align-items: center;
    gap: 7px;
    margin-top: 10px;
  }
  .img-blend-row input[type='checkbox'] {
    width: 14px;
    height: 14px;
    accent-color: #a78bfa;
    cursor: pointer;
    flex-shrink: 0;
  }
  .img-blend-row label {
    font-size: 0.76rem;
    color: var(--color-text-dim);
    cursor: pointer;
    user-select: none;
  }
  .img-blend-info {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    margin-top: 5px;
    min-height: 16px;
  }

  /* SVG icon grid (Ikoner tab) */
  .icon-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 4px;
    max-height: 190px;
    overflow-y: auto;
  }
  .icon-grid::-webkit-scrollbar { width: 4px; }
  .icon-grid::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.10);
    border-radius: 4px;
  }
  .icon-cell {
    aspect-ratio: 1;
    border-radius: 7px;
    border: 1px solid transparent;
    background: rgba(255, 255, 255, 0.04);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.12s, border-color 0.12s;
    color: var(--color-text-dim);
    padding: 4px;
  }
  .icon-cell:hover {
    background: rgba(255, 255, 255, 0.09);
    color: var(--color-text);
  }
  .icon-cell.selected {
    background: rgba(167, 139, 250, 0.15);
    border-color: rgba(167, 139, 250, 0.40);
    color: #a78bfa;
  }

  /* Image upload tab — drop zone */
  .img-drop-zone {
    border: 2px dashed rgba(255, 255, 255, 0.12);
    border-radius: 10px;
    padding: 20px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    position: relative;
  }
  .img-drop-zone:hover,
  .img-drop-zone.dragover {
    border-color: rgba(167, 139, 250, 0.50);
    background: rgba(167, 139, 250, 0.05);
  }
  .img-drop-zone input[type='file'] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
  }
  .img-drop-zone-icon {
    color: var(--color-text-muted);
    margin-bottom: 8px;
  }
  .img-drop-zone-text {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .img-drop-zone-text span { color: #a78bfa; }
  .img-preview-wrap {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 8px;
  }
  .img-preview-wrap img {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    object-fit: cover;
  }
  .img-preview-info {
    font-size: 0.8rem;
    color: var(--color-text-dim);
    flex: 1;
  }
  .img-clear-btn {
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 6px;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    padding: 4px 10px;
    cursor: pointer;
  }
  .img-clear-btn:hover {
    background: rgba(255, 255, 255, 0.07);
    color: var(--color-text);
  }
  .img-url-row {
    display: flex;
    gap: 6px;
    margin-top: 8px;
  }
  .img-url-row input {
    flex: 1;
    font-size: 0.78rem !important;
  }
  .img-url-btn {
    flex-shrink: 0;
    padding: 0 12px;
    height: 34px;
    border-radius: 7px;
    border: 1px solid rgba(167, 139, 250, 0.35);
    background: rgba(167, 139, 250, 0.10);
    color: #a78bfa;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
  }
  .img-url-btn:hover { background: rgba(167, 139, 250, 0.18); }
  .img-url-divider {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
    color: var(--color-text-muted);
    font-size: 0.7rem;
  }
  .img-url-divider::before,
  .img-url-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.07);
  }

  /* Custom-color "rainbow" swatch (next to the preset row) */
  .color-custom-wrap {
    position: relative;
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }
  .color-custom-wrap input[type='color'] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
    padding: 0;
    border: none;
  }
  .color-custom-btn {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    pointer-events: none;
    background: conic-gradient(red, yellow, lime, cyan, blue, magenta, red);
    border: 2px solid rgba(255, 255, 255, 0.20);
  }

  /* Override the default link page color row to use 22px swatches like
     the legacy (smaller than the 24px Plan modal swatches). */
  .ext-color-row {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .ext-color-swatch {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.12s, transform 0.12s;
    padding: 0;
  }
  .ext-color-swatch:hover { transform: scale(1.15); }
  .ext-color-swatch.selected { border-color: #fff; }

  /* ──────────────────────────────────────────────────────────────────────
   * Sport page — pill filters, event cards, source picker modal
   * ──────────────────────────────────────────────────────────────────── */

  /* Sport variables (scoped to .sport-page) */
  .sport-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 24px 28px 72px;
    position: relative;
    z-index: 1;
    --cc-color: #22d3ee;
    --bi-color: #9ca3af;
    --fb-color: #4ade80;
    --live: #ef4444;
    --today-accent: #f59e0b;
  }
  @media (max-width: 768px) {
    .sport-page { padding: 16px 14px 56px; }
  }

  .sport-title-desktop {
    display: none;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }
  @media (min-width: 769px) {
    .sport-title-desktop { display: flex; }
  }
  .sport-title-main {
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text);
    line-height: 1;
  }
  .sport-last-updated {
    margin-left: auto;
    font-size: 0.74rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .sport-live-dot {
    color: #22d3ee;
    animation: pulse 2s infinite;
    display: flex;
    align-items: center;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.35; }
  }

  /* Filter pills */
  .sport-filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }
  .sport-filter-btn {
    padding: 7px 15px;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.07);
    background: rgba(0, 0, 0, 0.28);
    color: var(--color-text-muted);
    cursor: pointer;
    font-size: 0.82rem;
    font-weight: 500;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    gap: 6px;
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }
  .sport-filter-btn svg { opacity: 0.7; }
  .sport-filter-btn:hover {
    border-color: rgba(255, 255, 255, 0.18);
    color: var(--color-text);
  }
  .sport-filter-btn:hover svg { opacity: 1; }
  .sport-filter-btn.active {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.22);
    color: var(--color-text);
  }
  .sport-filter-btn.active svg { opacity: 1; }

  /* "Vis tidligere" toggle button — has a strikethrough line by default */
  .sport-past-btn {
    margin-left: auto;
    flex-shrink: 0;
    padding: 5px 13px;
    border-radius: 20px;
    border: 1px solid var(--color-border);
    background: none;
    color: var(--color-text-muted);
    cursor: pointer;
    font-size: 0.76rem;
    font-weight: 500;
    transition: all 0.15s;
    position: relative;
    overflow: hidden;
  }
  .sport-past-btn::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 4px;
    right: 4px;
    height: 1.5px;
    background: currentColor;
    transform: translateY(-50%) rotate(-8deg);
    opacity: 0.7;
    transition: opacity 0.15s;
  }
  .sport-past-btn.active::after { opacity: 0; }
  .sport-past-btn:hover {
    border-color: var(--color-text-dim);
    color: var(--color-text-dim);
  }
  .sport-past-btn.active {
    background: var(--color-surface-2);
    border-color: var(--color-text-dim);
    color: var(--color-text);
  }

  /* Live now section */
  .live-now-section { margin-bottom: 24px; }
  .live-now-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }
  .live-now-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: #ef4444;
  }
  .live-pulse {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #ef4444;
    flex-shrink: 0;
    animation: pulse 1.2s infinite;
  }

  /* Date groups */
  .date-group { margin-bottom: 26px; }
  .date-label {
    font-size: 0.76rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--color-text-muted);
    margin-bottom: 9px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .date-label.today { color: #f59e0b; }
  .date-label.tomorrow { color: var(--color-text-dim); }
  .date-badge {
    background: #f59e0b;
    color: #000;
    font-size: 0.62rem;
    padding: 1px 6px;
    border-radius: 4px;
    font-weight: 800;
    letter-spacing: 0.06em;
  }

  /* Event cards */
  .events-grid {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .event-card {
    background: rgba(0, 0, 0, 0.28);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: var(--radius-sm);
    padding: 13px 15px;
    display: flex;
    align-items: center;
    gap: 14px;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, box-shadow 0.15s, transform 0.10s;
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }
  .event-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    border-radius: 4px 0 0 4px;
  }
  .event-card.cross_country::before { background: #22d3ee; }
  .event-card.biathlon::before      { background: #9ca3af; }
  .event-card.football::before      { background: #4ade80; }
  .event-card.cross_country {
    background: rgba(34, 211, 238, 0.008);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.5),
      inset 8px 0 32px rgba(34, 211, 238, 0.03),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }
  .event-card.biathlon {
    background: rgba(156, 163, 175, 0.009);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.5),
      inset 8px 0 32px rgba(156, 163, 175, 0.035),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }
  .event-card.football {
    background: rgba(74, 222, 128, 0.008);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.5),
      inset 8px 0 32px rgba(74, 222, 128, 0.03),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }
  .event-card:hover {
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(0, 0, 0, 0.38);
    transform: translateX(2px);
  }
  .event-card.live {
    border-color: rgba(239, 68, 68, 0.40);
    background: rgba(239, 68, 68, 0.04);
  }
  .event-time {
    min-width: 52px;
    text-align: center;
    flex-shrink: 0;
  }
  .event-start {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .event-body { flex: 1; min-width: 0; }
  .event-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .event-meta {
    display: flex;
    align-items: center;
    gap: 7px;
    margin-top: 5px;
    flex-wrap: wrap;
  }
  .event-arrow {
    color: var(--color-text-muted);
    flex-shrink: 0;
    opacity: 0.5;
  }
  .event-card:hover .event-arrow { opacity: 1; }

  /* Sport badges */
  .sport-badge {
    font-size: 0.66rem;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .sport-badge.cc       { background: rgba(34, 211, 238, 0.10); color: #22d3ee; border: 1px solid rgba(34, 211, 238, 0.28); }
  .sport-badge.bi       { background: rgba(156, 163, 175, 0.12); color: #9ca3af; border: 1px solid rgba(156, 163, 175, 0.30); }
  .sport-badge.fb       { background: rgba(74, 222, 128, 0.12); color: #4ade80; border: 1px solid rgba(74, 222, 128, 0.30); }
  .sport-badge.live     {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.30);
    animation: pulse 1.2s infinite;
  }
  .sport-badge.nrk      { background: rgba(59, 130, 246, 0.12); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.30); }
  .sport-badge.tv2      { background: rgba(34, 197, 94, 0.12); color: #4ade80; border: 1px solid rgba(34, 197, 94, 0.30); }
  .sport-badge.viaplay  { background: rgba(239, 68, 68, 0.12); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.30); }
  .sport-badge.nrkradio { background: rgba(249, 115, 22, 0.12); color: #fb923c; border: 1px solid rgba(249, 115, 22, 0.30); }
  .sport-badge.twe      { background: rgba(34, 211, 238, 0.10); color: #22d3ee; border: 1px solid rgba(34, 211, 238, 0.28); }

  /* Sport empty state */
  .sport-empty {
    text-align: center;
    padding: 44px 24px;
    color: var(--color-text-muted);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius);
    margin-top: 8px;
  }
  .sport-empty svg {
    opacity: 0.35;
    margin-bottom: 10px;
  }
  .sport-empty p { font-size: 0.9rem; }

  /* Sport source-picker modal */
  .sport-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 200;
  }
  .sport-modal {
    position: fixed;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    background: #1c1c1c;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 24px;
    width: 340px;
    max-width: 90vw;
    z-index: 201;
  }
  .sport-modal-close {
    position: absolute;
    top: 14px;
    right: 14px;
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 4px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }
  .sport-modal-close:hover { color: var(--color-text); }
  .sport-modal-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 6px;
  }
  .sport-modal-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 20px;
    line-height: 1.3;
  }
  .sport-modal-sources {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .source-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    border-radius: 9px;
    border: 1px solid var(--color-border);
    background: var(--color-surface-2);
    color: var(--color-text);
    cursor: pointer;
    font-size: 0.88rem;
    font-weight: 500;
    text-align: left;
    transition: border-color 0.15s, background 0.15s;
    text-decoration: none;
  }
  .source-btn:hover {
    border-color: rgba(255, 255, 255, 0.15);
    background: #1a1a1a;
  }
  .source-btn .src-name { flex: 1; }
  .source-btn .src-icon { flex-shrink: 0; }
  .source-btn .src-ext { color: var(--color-text-muted); flex-shrink: 0; }
  .source-btn.nrk     .src-icon { color: #60a5fa; }
  .source-btn.tv2     .src-icon { color: #4ade80; }
  .source-btn.viaplay .src-icon { color: #f87171; }
  .source-btn.radio   .src-icon { color: #fb923c; }
  .source-btn.twe     .src-icon { color: #22d3ee; }

  /* ──────────────────────────────────────────────────────────────────────
   * Gaming page — Steam wishlist + events with detail modal
   * ──────────────────────────────────────────────────────────────────── */
  .gaming-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 36px 28px 72px;
  }
  @media (max-width: 768px) {
    .gaming-page { padding: 24px 16px 56px; }
  }
  /* Gaming page header — slightly tighter than the global .page-header */
  .gaming-page .page-header { margin-bottom: 24px; }
  .gaming-page .page-header-eyebrow { margin-bottom: 6px; }
  .gaming-page .page-header-sub { font-size: 0.85rem; margin-top: 5px; }
  .gaming-updated {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    margin-top: 3px;
  }

  .gaming-filter-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .gaming-filter-btn {
    padding: 5px 14px;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.10);
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-text-dim);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }
  .gaming-filter-btn:hover {
    border-color: rgba(255, 255, 255, 0.20);
    color: var(--color-text);
  }
  .gaming-filter-btn.active {
    background: rgba(249, 115, 22, 0.12);
    border-color: rgba(249, 115, 22, 0.35);
    color: #f97316;
  }
  .gaming-filter-count {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin-left: auto;
  }

  .gaming-section-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 24px 0 10px;
  }
  .gaming-section-label:first-child { margin-top: 0; }

  .games-grid {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .game-card {
    display: flex;
    align-items: stretch;
    text-decoration: none;
    color: inherit;
    background: rgba(0, 0, 0, 0.28);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.15s, background 0.15s, transform 0.12s;
    cursor: pointer;
  }
  .game-card:hover {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(0, 0, 0, 0.38);
    transform: translateX(2px);
  }
  .game-card.on-sale {
    border-color: rgba(74, 222, 128, 0.18);
  }
  .game-img-wrap {
    position: relative;
    width: 184px;
    min-width: 184px;
    flex-shrink: 0;
    overflow: hidden;
  }
  @media (max-width: 768px) {
    .game-img-wrap { width: 110px; min-width: 110px; }
  }
  .game-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: rgba(255, 255, 255, 0.04);
    display: block;
  }
  .img-ptags {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 16px 5px 5px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.75) 0%, transparent 100%);
    display: flex;
    flex-direction: column;
    gap: 2px;
    align-items: flex-start;
  }
  .game-info {
    flex: 1;
    min-width: 0;
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
  }
  .game-name {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .game-tags {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }
  .game-tag {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 2px 7px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.09);
    color: var(--color-text-muted);
    text-transform: uppercase;
  }
  .game-price-col {
    flex-shrink: 0;
    padding: 12px 18px;
    min-width: 110px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    gap: 3px;
  }
  @media (max-width: 768px) {
    .game-price-col { min-width: 80px; padding: 8px 10px; }
  }
  .sale-badge {
    font-size: 0.72rem;
    font-weight: 800;
    padding: 3px 8px;
    border-radius: 5px;
    background: #4ade80;
    color: #052e16;
    letter-spacing: 0.02em;
  }
  .game-orig-price {
    font-size: 0.74rem;
    color: var(--color-text-muted);
    text-decoration: line-through;
  }
  .game-price {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .game-price.free { color: #4ade80; }
  .price-na {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .ptag {
    font-size: 0.58rem;
    font-weight: 800;
    padding: 2px 5px;
    border-radius: 3px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  @media (max-width: 768px) {
    .ptag { font-size: 0.52rem; padding: 1px 4px; }
  }
  .ptag-hot {
    background: rgba(239, 68, 68, 0.22);
    border: 1px solid rgba(239, 68, 68, 0.55);
    color: #fca5a5;
  }
  .ptag-rare {
    background: rgba(251, 146, 60, 0.18);
    border: 1px solid rgba(251, 146, 60, 0.45);
    color: #fdba74;
  }

  .gaming-state-box {
    text-align: center;
    padding: 60px 20px;
    color: var(--color-text-dim);
    font-size: 0.88rem;
  }

  /* Gaming events list */
  .gaming-events-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .gaming-event-card {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: rgba(0, 0, 0, 0.28);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: var(--radius);
    padding: 16px 18px;
    transition: border-color 0.15s, background 0.15s;
    text-decoration: none;
    color: inherit;
  }
  .gaming-event-card:hover {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(0, 0, 0, 0.38);
  }
  .gaming-event-card.past {
    opacity: 0.38;
    filter: grayscale(0.6);
    pointer-events: none;
  }
  .gaming-event-card.live {
    border-color: rgba(239, 68, 68, 0.40);
    background: rgba(239, 68, 68, 0.04);
  }
  .gaming-event-date-col {
    flex-shrink: 0;
    width: 52px;
    text-align: center;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 7px 4px;
  }
  .gaming-event-date-day {
    font-size: 1.4rem;
    font-weight: 800;
    line-height: 1;
    color: var(--color-text);
  }
  .gaming-event-date-mon {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-top: 2px;
  }
  .gaming-event-info { flex: 1; min-width: 0; }
  .gaming-event-name {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .gaming-event-time {
    font-size: 0.76rem;
    color: var(--color-text-dim);
    margin-top: 3px;
  }
  .gaming-event-desc {
    font-size: 0.78rem;
    color: var(--color-text-dim);
    margin-top: 5px;
    line-height: 1.5;
  }
  .gaming-event-badge {
    flex-shrink: 0;
    align-self: center;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 20px;
  }
  .badge-live-now {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.30);
    animation: pulse 1.5s infinite;
  }
  .badge-soon {
    background: rgba(249, 115, 22, 0.12);
    color: #f97316;
    border: 1px solid rgba(249, 115, 22, 0.30);
  }
  .badge-upcoming {
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-text-muted);
    border: 1px solid rgba(255, 255, 255, 0.10);
  }
  .events-past-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 20px 0 8px;
  }

  /* Gaming detail modal */
  .gaming-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 500;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .gaming-modal-panel {
    position: fixed;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 16px;
    width: calc(100vw - 40px);
    max-width: 560px;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.7);
    z-index: 501;
  }
  .gaming-modal-close {
    position: absolute;
    top: 12px;
    right: 14px;
    z-index: 10;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.10);
    color: #aaa;
    font-size: 1rem;
    line-height: 1;
    padding: 5px 9px;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .gaming-modal-close:hover {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
  }
  .gaming-modal-hero {
    position: relative;
    width: 100%;
    height: 200px;
    overflow: hidden;
    border-radius: 16px 16px 0 0;
  }
  .gaming-modal-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .gaming-modal-hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, #111 0%, rgba(0, 0, 0, 0.30) 60%, transparent 100%);
  }
  .gaming-modal-body { padding: 16px 20px 24px; }
  .gaming-modal-name {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin-bottom: 10px;
    line-height: 1.2;
  }
  .gaming-modal-price-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }
  .gaming-modal-ptags {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .gaming-modal-chart-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 8px;
  }
  .gaming-modal-chart { width: 100%; }
  .gaming-modal-chart-empty {
    text-align: center;
    padding: 40px 0;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }
  .gaming-modal-chart-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 40px 0;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }
  .chart-spinner {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.10);
    border-top-color: #888;
    animation: spin 0.7s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .gaming-modal-steam-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-top: 18px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: var(--color-text);
    text-decoration: none;
    padding: 9px 16px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    transition: background 0.15s, border-color 0.15s;
  }
  .gaming-modal-steam-btn:hover {
    background: rgba(255, 255, 255, 0.10);
    border-color: rgba(255, 255, 255, 0.22);
  }

  /* ──────────────────────────────────────────────────────────────────────
   * Skole page — course panels grid + announcements
   * ──────────────────────────────────────────────────────────────────── */
  .skole-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 28px 32px 72px;
  }
  @media (max-width: 768px) {
    .skole-page { padding: 16px 14px 56px; }
  }

  .skole-title-desktop {
    display: none;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }
  @media (min-width: 769px) {
    .skole-title-desktop { display: flex; }
  }
  .skole-title-main {
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text);
  }
  .skole-title-sub {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    margin-left: auto;
  }

  .skole-section { margin-bottom: 36px; }
  .skole-section-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .skole-section-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .skole-section-title {
    font-size: 0.76rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-dim);
  }
  .skole-section-count {
    margin-left: 6px;
    font-size: 0.65rem;
    font-weight: 700;
    background: var(--color-surface-2);
    color: var(--color-text-muted);
    padding: 1px 7px;
    border-radius: 10px;
  }

  /* Course panels grid */
  .course-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  @media (max-width: 860px) {
    .course-panels { grid-template-columns: 1fr; }
  }
  .cp {
    background: rgba(0, 0, 0, 0.28);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.15s;
  }
  .cp-header {
    padding: 18px 20px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .cp-hrow {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .cp-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .cp-name {
    font-size: 0.95rem;
    font-weight: 700;
    flex: 1;
  }
  .cp-canvas-btn {
    font-size: 0.70rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 4px 10px;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.10);
    color: var(--color-text-dim);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .cp-canvas-btn:hover {
    border-color: rgba(255, 255, 255, 0.22);
    color: var(--color-text);
  }
  .cp-bar-wrap {
    height: 3px;
    background: rgba(255, 255, 255, 0.07);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 8px;
  }
  .cp-bar-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 0.4s;
  }
  .cp-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .cp-ratio { font-size: 0.72rem; color: var(--color-text-muted); }
  .cp-pending { font-size: 0.70rem; color: var(--color-text-muted); }
  .cp-done-tag { font-size: 0.70rem; color: #4ade80; }
  .cp-body { padding: 16px 20px 20px; }
  .cp-section-lbl {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 10px;
  }

  /* Assignment cards (next-up) */
  .assign-list {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .assign-card {
    display: flex;
    align-items: center;
    gap: 14px;
    background: rgba(0, 0, 0, 0.28);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s, background 0.15s, box-shadow 0.15s, transform 0.10s;
    overflow: hidden;
    position: relative;
    padding: 13px 15px;
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }
  .assign-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    border-radius: 4px 0 0 4px;
    background: var(--bar-color, rgba(255, 255, 255, 0.20));
  }
  .assign-card:hover {
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(0, 0, 0, 0.38);
    transform: translateX(2px);
  }
  .assign-card.urgent {
    border-color: rgba(239, 68, 68, 0.25);
    background: rgba(239, 68, 68, 0.03);
  }
  .assign-card.overdue {
    border-color: rgba(239, 68, 68, 0.15);
    opacity: 0.6;
  }
  .assign-card.soon {
    border-color: rgba(251, 191, 36, 0.15);
  }
  .assign-due-col {
    min-width: 52px;
    text-align: center;
    flex-shrink: 0;
  }
  .assign-due-top {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    line-height: 1;
    margin-bottom: 3px;
  }
  .assign-due-top.urgent { color: #f87171; }
  .assign-due-top.soon { color: #fbbf24; }
  .assign-due-top.overdue { color: var(--color-text-muted); }
  .assign-due-main {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
  }
  .assign-due-main.urgent { color: #f87171; }
  .assign-due-main.soon { color: #fbbf24; }
  .assign-due-main.overdue { color: var(--color-text-muted); }
  .assign-body { flex: 1; min-width: 0; }
  .assign-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 5px;
  }
  .assign-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .assign-course-tag {
    font-size: 0.63rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 1px 6px;
    border-radius: 4px;
    border: 1px solid transparent;
    text-transform: uppercase;
  }
  .assign-arrow {
    color: var(--color-text-muted);
    opacity: 0.5;
    flex-shrink: 0;
  }
  .assign-card:hover .assign-arrow { opacity: 1; }

  /* Course panel link buttons */
  .cp-links {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .cp-link-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.07);
    background: rgba(255, 255, 255, 0.02);
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.84rem;
    font-weight: 500;
    transition: border-color 0.15s, background 0.15s;
  }
  .cp-link-btn:hover {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.05);
  }
  .cp-link-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }
  .cp-link-icon.orange { color: #fb923c; }
  .cp-link-icon.gray   { color: #888; }
  .cp-link-icon.blue   { color: #60a5fa; }
  .cp-link-icon.green  { color: #4ade80; }
  .cp-link-label { flex: 1; }
  .cp-link-ext {
    color: var(--color-text-muted);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  /* Announcements */
  .ann-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .ann-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .ann-card {
    background: rgba(0, 0, 0, 0.22);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: var(--radius-sm);
    padding: 14px 16px;
    transition: border-color 0.15s, background 0.15s;
  }
  .ann-link:hover .ann-card {
    border-color: rgba(255, 255, 255, 0.13);
    background: rgba(0, 0, 0, 0.35);
  }
  .ann-head {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 7px;
    flex-wrap: wrap;
  }
  .ann-tag {
    font-size: 0.63rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 1px 6px;
    border-radius: 4px;
    border: 1px solid transparent;
    text-transform: uppercase;
    flex-shrink: 0;
  }
  .ann-title {
    font-size: 0.9rem;
    font-weight: 600;
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ann-date {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .skole-empty-state {
    background: rgba(0, 0, 0, 0.22);
    border: 1px dashed rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-sm);
    padding: 13px 15px;
    min-height: 74px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .skole-empty-label {
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  /* ──────────────────────────────────────────────────────────────────────
   * Notes page — full-height list + contenteditable editor
   * ──────────────────────────────────────────────────────────────────── */
  .notes-shell {
    display: flex;
    flex: 1;
    overflow: hidden;
    height: 100vh;
  }
  @media (max-width: 768px) {
    .notes-shell { height: calc(100vh - 60px); }
  }

  .notes-list-panel {
    width: 260px;
    flex-shrink: 0;
    border-right: 1px solid rgba(255, 255, 255, 0.07);
    display: flex;
    flex-direction: column;
    background: rgba(0, 0, 0, 0.18);
    overflow: hidden;
  }
  .notes-list-header {
    padding: 16px 16px 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }
  .notes-list-title {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .notes-btn-new {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(167, 139, 250, 0.12);
    border: 1px solid rgba(167, 139, 250, 0.25);
    border-radius: 6px;
    color: #a78bfa;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 5px 10px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .notes-btn-new:hover {
    background: rgba(167, 139, 250, 0.20);
    border-color: rgba(167, 139, 250, 0.40);
  }
  .notes-list {
    flex: 1;
    overflow-y: auto;
    padding: 8px;
  }
  .notes-list::-webkit-scrollbar { width: 4px; }
  .notes-list::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.10); border-radius: 4px; }

  .note-item {
    padding: 10px 12px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    margin-bottom: 2px;
    border: 1px solid transparent;
    transition: background 0.12s, border-color 0.12s;
  }
  .note-item:hover {
    background: rgba(255, 255, 255, 0.04);
  }
  .note-item.active {
    background: rgba(167, 139, 250, 0.08);
    border-color: rgba(167, 139, 250, 0.20);
  }
  .note-item-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .note-item.active .note-item-title { color: #a78bfa; }
  .note-item-preview {
    font-size: 0.74rem;
    color: var(--color-text-dim);
    margin-top: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.4;
  }
  .note-item-date {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    margin-top: 4px;
  }
  .notes-empty-state {
    padding: 32px 16px;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.82rem;
    line-height: 1.6;
  }

  .notes-editor-panel {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .editor-toolbar {
    padding: 12px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
    gap: 12px;
  }
  .editor-title-input {
    flex: 1;
    min-width: 0;
    background: none;
    border: none;
    outline: none;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    font-family: inherit;
    caret-color: #a78bfa;
  }
  .editor-title-input::placeholder { color: var(--color-text-muted); }
  .editor-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .editor-saved-label {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    transition: opacity 0.3s;
  }
  .btn-delete-notes {
    display: flex;
    align-items: center;
    gap: 5px;
    background: none;
    border: 1px solid rgba(239, 68, 68, 0.20);
    border-radius: 6px;
    color: rgba(239, 68, 68, 0.6);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 5px 10px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .btn-delete-notes:hover {
    background: rgba(239, 68, 68, 0.10);
    border-color: rgba(239, 68, 68, 0.40);
    color: #ef4444;
  }

  .format-toolbar {
    padding: 6px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
    background: rgba(0, 0, 0, 0.15);
    flex-wrap: wrap;
  }
  .fmt-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: none;
    border: 1px solid transparent;
    border-radius: 5px;
    color: var(--color-text-dim);
    font-size: 0.82rem;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
    flex-shrink: 0;
  }
  .fmt-btn:hover {
    background: rgba(255, 255, 255, 0.07);
    color: var(--color-text);
    border-color: rgba(255, 255, 255, 0.10);
  }
  .fmt-btn.active {
    background: rgba(167, 139, 250, 0.15);
    color: #a78bfa;
    border-color: rgba(167, 139, 250, 0.30);
  }
  .fmt-sep {
    width: 1px;
    height: 18px;
    background: rgba(255, 255, 255, 0.09);
    margin: 0 4px;
    flex-shrink: 0;
  }
  .fmt-select {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 5px;
    color: var(--color-text-dim);
    font-size: 0.78rem;
    font-family: inherit;
    padding: 3px 6px;
    cursor: pointer;
    outline: none;
    transition: border-color 0.12s;
  }
  .fmt-select:hover {
    border-color: rgba(255, 255, 255, 0.18);
    color: var(--color-text);
  }
  .fmt-color-wrap {
    position: relative;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }
  .fmt-color-wrap input[type='color'] {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    border: none;
    padding: 0;
  }
  .fmt-color-swatch {
    width: 28px;
    height: 28px;
    border-radius: 5px;
    border: 1px solid rgba(255, 255, 255, 0.10);
    background: none;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
  }
  .fmt-color-letter {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-text-dim);
    line-height: 1;
  }
  .fmt-color-bar {
    width: 14px;
    height: 3px;
    border-radius: 2px;
    margin-top: 1px;
    background: #e8e8e2;
  }

  .editor-body {
    flex: 1;
    overflow-y: auto;
    padding: 20px 24px;
  }
  .editor-body::-webkit-scrollbar { width: 4px; }
  .editor-body::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.10); border-radius: 4px; }
  .editor-content {
    width: 100%;
    height: 100%;
    min-height: 400px;
    background: none;
    border: none;
    outline: none;
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--color-text);
    font-family: inherit;
    caret-color: #a78bfa;
    word-break: break-word;
  }
  .editor-content:empty::before {
    content: attr(data-placeholder);
    color: var(--color-text-muted);
    pointer-events: none;
  }
  .editor-content hr {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    margin: 12px 0;
  }

  .no-note-state {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 12px;
    color: var(--color-text-muted);
    text-align: center;
    padding: 40px;
  }
  .no-note-state svg { opacity: 0.25; }
  .no-note-state p {
    font-size: 0.85rem;
    line-height: 1.6;
  }

  /* Print / PDF export — only show the editor body */
  @media print {
    body * { visibility: hidden; }
    #editor-body, #editor-body * { visibility: visible; }
    #editor-body {
      position: fixed;
      left: 0;
      top: 0;
      width: 100%;
      color: #111 !important;
      background: #fff !important;
      font-size: 12pt;
      line-height: 1.6;
      padding: 20mm;
    }
    #editor-body hr { border-top: 1px solid #aaa; }
  }

  /* ──────────────────────────────────────────────────────────────────────
   * Todo page — list + kanban view, drag-reorder, modal
   * ──────────────────────────────────────────────────────────────────── */
  .todo-page {
    max-width: 960px;
    width: 100%;
    margin: 0 auto;
    padding: 24px 28px 72px;
  }
  @media (max-width: 768px) {
    .todo-page { padding: 16px 14px 56px; }
  }

  .todo-title-desktop {
    display: none;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }
  @media (min-width: 769px) {
    .todo-title-desktop { display: flex; }
  }
  .todo-title-main {
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text);
    line-height: 1;
  }
  .todo-header-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-left: auto;
  }
  .view-switch {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: var(--radius-sm);
    padding: 3px;
    gap: 2px;
  }
  .view-switch-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px 9px;
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 600;
    border: none;
    background: transparent;
    color: var(--color-text-dim);
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .view-switch-btn:hover { color: var(--color-text); }
  .view-switch-btn.active {
    background: rgba(167, 139, 250, 0.18);
    color: #a78bfa;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.35);
  }
  .btn-new-task {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(167, 139, 250, 0.15);
    border: 1px solid rgba(167, 139, 250, 0.30);
    border-radius: var(--radius-sm);
    color: #a78bfa;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 9px 16px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .btn-new-task:hover {
    background: rgba(167, 139, 250, 0.25);
    border-color: rgba(167, 139, 250, 0.50);
  }

  .todo-section-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 10px;
  }
  .todo-section-label + .todo-section-label { margin-top: 28px; }

  .todo-list {
    display: flex;
    flex-direction: column;
    gap: 7px;
    margin-bottom: 32px;
  }

  .todo-item {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 13px 14px 13px 18px;
    background: #050505;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 11px;
    cursor: grab;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.35);
    transition: transform 0.16s, box-shadow 0.16s, border-color 0.16s;
    overflow: hidden;
  }
  .todo-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
  }
  .todo-item.priority-high::before {
    background: linear-gradient(180deg, #f87171 0%, rgba(248, 113, 113, 0.25) 100%);
  }
  .todo-item.priority-medium::before {
    background: linear-gradient(180deg, #60a5fa 0%, rgba(96, 165, 250, 0.25) 100%);
  }
  .todo-item.priority-low::before {
    background: linear-gradient(180deg, #4ade80 0%, rgba(74, 222, 128, 0.25) 100%);
  }
  .todo-item:hover {
    transform: translateY(-1px);
    border-color: rgba(255, 255, 255, 0.13);
  }
  .todo-item.priority-high:hover {
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(248, 113, 113, 0.18) inset;
  }
  .todo-item.priority-medium:hover {
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(96, 165, 250, 0.14) inset;
  }
  .todo-item.priority-low:hover {
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(74, 222, 128, 0.14) inset;
  }
  .todo-item:active { cursor: grabbing; transform: translateY(0); }
  .todo-item.done { opacity: 0.3; }

  .todo-check {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 1px;
    border: 1.5px solid rgba(255, 255, 255, 0.18);
    border-radius: 50%;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    padding: 0;
  }
  .todo-item.priority-high .todo-check:hover { border-color: rgba(248, 113, 113, 0.7); }
  .todo-item.priority-medium .todo-check:hover { border-color: rgba(96, 165, 250, 0.65); }
  .todo-item.priority-low .todo-check:hover { border-color: rgba(74, 222, 128, 0.65); }
  .todo-item.done .todo-check {
    background: rgba(167, 139, 250, 0.20);
    border-color: rgba(167, 139, 250, 0.50);
  }

  .todo-body {
    flex: 1;
    min-width: 0;
  }
  .todo-title {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.45;
  }
  .todo-item.done .todo-title {
    text-decoration: line-through;
    color: var(--color-text-muted);
  }
  .todo-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 5px;
    flex-wrap: wrap;
  }
  .todo-badge {
    font-size: 0.59rem;
    font-weight: 800;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }
  .todo-badge.high   { color: rgba(248, 113, 113, 0.6); }
  .todo-badge.medium { color: rgba(96, 165, 250, 0.55); }
  .todo-badge.low    { color: rgba(74, 222, 128, 0.55); }
  .todo-deadline {
    font-size: 0.71rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 3px;
  }
  .todo-deadline.overdue { color: rgba(248, 113, 113, 0.75); }

  .todo-actions {
    display: flex;
    align-items: center;
    gap: 1px;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .todo-actions button {
    opacity: 0;
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 5px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    transition: all 0.12s;
  }
  .todo-item:hover .todo-actions button { opacity: 1; }
  .todo-actions .delete:hover { color: rgba(248, 113, 113, 0.85); }
  .todo-actions .edit:hover { color: rgba(255, 255, 255, 0.65); }

  .todo-empty-state {
    text-align: center;
    padding: 60px 20px;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    line-height: 1.7;
  }
  .todo-empty-state svg {
    opacity: 0.12;
    margin: 0 auto 12px;
    display: block;
  }

  /* Kanban columns */
  .columns-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 14px;
    margin-bottom: 32px;
    align-items: start;
  }
  .priority-col {
    background: rgba(4, 4, 4, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .priority-col.high   { border-top: 2px solid rgba(248, 113, 113, 0.45); }
  .priority-col.medium { border-top: 2px solid rgba(96, 165, 250, 0.40); }
  .priority-col.low    { border-top: 2px solid rgba(74, 222, 128, 0.40); }

  .col-header {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 14px 16px 13px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  .col-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .priority-col.high   .col-dot { background: #f87171; box-shadow: 0 0 8px rgba(248, 113, 113, 0.55); }
  .priority-col.medium .col-dot { background: #60a5fa; box-shadow: 0 0 8px rgba(96, 165, 250, 0.50); }
  .priority-col.low    .col-dot { background: #4ade80; box-shadow: 0 0 8px rgba(74, 222, 128, 0.50); }
  .col-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
  }
  .col-add-btn {
    margin-left: auto;
    background: none;
    border: none;
    cursor: pointer;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.25);
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
    font-size: 1.1rem;
    line-height: 1;
    padding: 0;
  }
  .col-add-btn:hover {
    color: rgba(255, 255, 255, 0.75);
    background: rgba(255, 255, 255, 0.07);
  }
  .col-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 12px;
    min-height: 80px;
  }
  .col-list .todo-item { border-radius: 9px; }

  /* Todo modal — Plan-style compact but with right-aligned buttons */
  .todo-modal-fields {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .todo-field {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .todo-field > label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .todo-field input {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: var(--radius-sm);
    padding: 10px 14px;
    font-size: 0.9rem;
    color: var(--color-text);
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
  }
  .todo-field input:focus {
    border-color: rgba(167, 139, 250, 0.50);
  }

  .priority-row {
    display: flex;
    gap: 8px;
  }
  .pri-btn {
    flex: 1;
    padding: 8px 4px;
    border-radius: var(--radius-sm);
    font-size: 0.78rem;
    font-weight: 700;
    cursor: pointer;
    border: 1.5px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    color: var(--color-text-dim);
    transition: all 0.15s;
    text-align: center;
  }
  .pri-btn[data-p='low'].selected {
    background: rgba(74, 222, 128, 0.12);
    border-color: rgba(74, 222, 128, 0.40);
    color: #4ade80;
  }
  .pri-btn[data-p='medium'].selected {
    background: rgba(96, 165, 250, 0.12);
    border-color: rgba(96, 165, 250, 0.40);
    color: #60a5fa;
  }
  .pri-btn[data-p='high'].selected {
    background: rgba(239, 68, 68, 0.12);
    border-color: rgba(239, 68, 68, 0.40);
    color: #f87171;
  }

  .todo-modal-actions {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
    margin-top: 4px;
  }
  .btn-cancel-todo {
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: var(--radius-sm);
    color: var(--color-text-dim);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 9px 18px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .btn-cancel-todo:hover { background: rgba(255, 255, 255, 0.05); }
  .btn-save-todo {
    background: rgba(167, 139, 250, 0.20);
    border: 1px solid rgba(167, 139, 250, 0.40);
    border-radius: var(--radius-sm);
    color: #a78bfa;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 9px 22px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .btn-save-todo:hover { background: rgba(167, 139, 250, 0.35); }
  .btn-delete-todo {
    background: none;
    border: 1px solid rgba(248, 113, 113, 0.25);
    border-radius: var(--radius-sm);
    color: rgba(248, 113, 113, 0.75);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 9px 16px;
    cursor: pointer;
    transition: background 0.15s;
    margin-right: auto;
  }
  .btn-delete-todo:hover {
    background: rgba(248, 113, 113, 0.10);
  }
}
